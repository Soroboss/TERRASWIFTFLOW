# ═══════════════════════════════════════════════════════════════════
# TerraSwiftFlow — Variables d'environnement
# Copiez vers .env.local (dev) ou configurez dans Vercel Dashboard
# ═══════════════════════════════════════════════════════════════════

# ─── InsForge (obligatoire) ───────────────────────────────────────
# URL OSS du projet (depuis .insforge/project.json → oss_host)
NEXT_PUBLIC_INSFORGE_URL=https://ecugv5a9.eu-central.insforge.app

# Clé publique anon — npx @insforge/cli secrets get ANON_KEY
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Clé admin serveur uniquement — .insforge/project.json → api_key
# ⚠️ JAMAIS en NEXT_PUBLIC_ — sensible
INSFORGE_API_KEY=

# URL publique de l'app (OAuth, emails, redirects)
# Dev : http://localhost:3000
# Prod Vercel : https://votre-projet.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Vercel Production (recommandé) ─────────────────────────────────
# Ajoutez ces variables dans : Vercel → Project → Settings → Environment Variables
#
# | Variable                      | Environnement      | Secret |
# |-------------------------------|--------------------|--------|
# | NEXT_PUBLIC_INSFORGE_URL      | Production, Preview| Non    |
# | NEXT_PUBLIC_INSFORGE_ANON_KEY | Production, Preview| Oui    |
# | INSFORGE_API_KEY              | Production, Preview| Oui    |
# | NEXT_PUBLIC_APP_URL           | Production         | Non    |
# | UPSTASH_REDIS_REST_URL        | Production, Preview| Oui    |
# | UPSTASH_REDIS_REST_TOKEN      | Production, Preview| Oui    |
#
# CLI Vercel :
#   vercel env add NEXT_PUBLIC_INSFORGE_URL production
#   vercel env pull .env.local

# ─── Upstash Redis (rate limiting production) ─────────────────────
# Marketplace Vercel : https://vercel.com/marketplace/upstash
# Sans ces variables → rate limit en mémoire (dev uniquement)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
